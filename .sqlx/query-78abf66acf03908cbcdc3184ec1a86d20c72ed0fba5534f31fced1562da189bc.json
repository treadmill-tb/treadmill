  "query": "select g.id, g.name, g.owner_subject, g.label, g.public, g.created_at\n           from tml_switchboard.image_groups g\n           where g.public\n              or exists (\n                  select 1 from tml_switchboard.principals($1) p\n                  where p.id = g.owner_subject\n              )\n           order by g.created_at",
