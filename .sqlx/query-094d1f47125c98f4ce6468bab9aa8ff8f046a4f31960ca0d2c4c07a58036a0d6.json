{
  "db_name": "PostgreSQL",
  "query": "\n        update tml_switchboard.jobs\n        set job_state = 'finalized',\n            termination_reason = $2,\n            exit_message = $3,\n            initializing_stage = null,\n            terminated_at = $4\n        where job_id = $1 and job_state <> 'finalized'\n        returning job_id\n        ",
